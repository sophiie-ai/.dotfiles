# Sophiie Engineering Dotfiles — Brewfile
# Usage: brew bundle --file=Brewfile

cask_args appdir: "/Applications"

# === Shell ===
brew "zsh"
brew "direnv"                 # Per-directory env vars

# === Node.js & JS Tooling ===
brew "node"                   # Node.js (latest)
brew "pnpm"                   # Package manager
brew "corepack"               # Node.js package manager shims

# === Version Control ===
brew "git"
brew "gh"                     # GitHub CLI
brew "git-lfs"                # Large file storage
brew "gnupg"                  # GPG for commit signing

# === Search & File Tools ===
brew "jq"                     # JSON processor
brew "tree"                   # Directory tree view

# === Infrastructure & Cloud ===
brew "awscli"                 # AWS CLI (SST deploys)

# === Terminal Multiplexer ===
brew "tmux"

# === Containers ===
cask "orbstack"               # Docker Desktop alternative (lightweight)

